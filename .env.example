POSTGRES_USER=rtc
POSTGRES_PASSWORD=rtc
POSTGRES_DB=rtc

# Used by the backend container to connect to the postgres service
DATABASE_URL=postgres://rtc:rtc@postgres:5432/rtc

RUST_LOG=info

# Public URL used by the frontend (browser) to reach the backend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_GIPHY_API_KEY=
