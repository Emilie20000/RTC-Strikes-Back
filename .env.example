# ==============================================================================
# CONFIGURATION GÉNÉRALE (DOCKER & BACKEND)
# ==============================================================================

# --- DATABASE (PostgreSQL) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=snouwzrtc
DATABASE_URL=postgresql://postgres:password@postgres:5432/snouwzrtc

# --- BACKEND ---
PORT=8080
RUST_LOG=info
REDIS_URL=redis://redis:6379

# --- CORS (TRÈS IMPORTANT POUR TAURI & WEB) ---
# Liste des URLs autorisées séparées par des virgules
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,tauri://localhost,https://tauri.localhost

# ==============================================================================
# CONFIGURATION FRONTEND (UTILISÉE PAR DOCKER COMPOSE)
# ==============================================================================
# Note: Pour le build Tauri ou Next.js standalone, les fichiers 
# frontend/.env.development et frontend/.env.production sont prioritaires.

NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_GIPHY_API_KEY=zfChInVE6Geu2RUVD6SfBSxxtl9oFEe3
