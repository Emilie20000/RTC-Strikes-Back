##### Database
POSTGRES_USER=yourpguser
POSTGRES_PASSWORD=yourpgpassword
POSTGRES_DB=yourpgdb
DATABASE_URL=yourdatabaseurl
#####

##### Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
# NEXT_PUBLIC_API_BASE_URL la valeur etre remplacé par l'url de render en cas de deployement
NEXT_PUBLIC_GIPHY_API_KEY=yourgiphyapikey
#####

##### Backend
RUST_LOG=info
REDIS_URL=redis://redis:6379
